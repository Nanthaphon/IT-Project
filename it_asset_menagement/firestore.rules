rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ══════════════════════════════════════════════════════════
       Helper functions
       ══════════════════════════════════════════════════════════ */
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin = ผู้ใช้ที่ login ด้วย email/password และมี doc ใน admin_users
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // SuperAdmin = admin ที่ตั้ง isSuperAdmin = true
    function isSuperAdmin() {
      return isAdmin() &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isSuperAdmin == true;
    }

    // ฟิลด์ที่ staff อนุญาตให้แก้ profile ตัวเองได้เท่านั้น
    // ❌ ไม่รวม manager — เฉพาะ admin จัดการ
    function staffEditableFields() {
      return ['fullName','fullNameEng','nickname','position','department','company','phone','m365Email','m365Password','updatedAt'];
    }

    /* ══════════════════════════════════════════════════════════
       employees — ต้อง login (admin หรือ staff via custom token),
                   staff login ไม่ต้องอ่าน collection นี้ (CF ค้นเอง)
       ══════════════════════════════════════════════════════════ */
    match /employees/{empId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Update: admin แก้อะไรก็ได้  |  staff (via custom token) แก้เฉพาะฟิลด์ profile
      allow update: if isAdmin() ||
        (isSignedIn() &&
         request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasOnly(staffEditableFields()));
    }

    match /deleted_employees/{id} {
      allow read, write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════════════
       settings (dropdown options, app config) — read public, write admin
       ══════════════════════════════════════════════════════════ */
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════════════
       assets / accessories / licenses / office_supplies
       — ต้อง login (admin, hr, staff); write admin เท่านั้น
       ══════════════════════════════════════════════════════════ */
    match /assets/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /accessories/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /licenses/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /office_supplies/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /bundled_items/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* ══════════════════════════════════════════════════════════
       Requests — ต้อง login ก่อน create (staff via custom token),
                  admin เท่านั้นที่ update/delete
       ══════════════════════════════════════════════════════════ */
    match /repair_requests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['empId', 'empName']);
      allow update, delete: if isAdmin();
    }
    match /supply_requests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['empId', 'empName']);
      allow update, delete: if isAdmin();
    }
    match /replacement_requests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['empId', 'empName']);
      allow update, delete: if isAdmin();
    }

    /* ══════════════════════════════════════════════════════════
       Transactions & ไฟล์แนบ — admin เท่านั้น
       (ประวัติเบิก-คืน, ภาพประกอบ, เอกสารใบกำกับ ฯลฯ)
       ══════════════════════════════════════════════════════════ */
    match /assets_transactions/{id} {
      allow read, write: if isAdmin();
    }
    match /accessories_transactions/{id} {
      allow read, write: if isAdmin();
    }
    match /licenses_transactions/{id} {
      allow read, write: if isAdmin();
    }
    match /transaction_attachments/{id} {
      allow read, write: if isAdmin();
    }
    match /asset_purchase_docs/{id} {
      allow read, write: if isAdmin();
    }
    match /printed_documents/{docId} {
      allow read, write: if isAdmin();
      match /chunks/{chunkId} {
        allow read, write: if isAdmin();
      }
      match /signed_chunks/{chunkId} {
        allow read, write: if isAdmin();
      }
    }

    /* ══════════════════════════════════════════════════════════
       staff_passwords — admin อ่านได้ (เพื่อ visibility),
                         เขียนได้เฉพาะ Vercel API (admin SDK bypass)
       ══════════════════════════════════════════════════════════ */
    match /staff_passwords/{empDocId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* ══════════════════════════════════════════════════════════
       line_users — เก็บโดย Cloud webhook (admin SDK)
       admin อ่านได้เพื่อหยิบ userId ไปตั้งใน "ตั้งค่าระบบ"
       ══════════════════════════════════════════════════════════ */
    match /line_users/{userId} {
      allow read: if isAdmin();
      allow write: if false; // webhook ใช้ admin SDK bypass rules
    }

    /* ══════════════════════════════════════════════════════════
       admin_users — เฉพาะ admin อ่าน, SuperAdmin จัดการ
       ══════════════════════════════════════════════════════════ */
    match /admin_users/{uid} {
      allow read: if isAdmin();
      allow create: if isSuperAdmin();
      // Admin คนนั้นแก้ doc ตัวเองได้ (เช่นเปลี่ยน displayName)
      allow update: if isSuperAdmin() || (isAdmin() && request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    /* ══════════════════════════════════════════════════════════
       Default — ปฏิเสธทั้งหมด (กัน collection ที่ลืม whitelist)
       ══════════════════════════════════════════════════════════ */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
